{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest",
        "--executable-path",
        "/usr/bin/chromium",
        "--browser",
        "chromium"
      ],
      "enabled": true
    }
  }
}
